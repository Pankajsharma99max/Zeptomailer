# ZeptoMail Configuration
ZEPTOMAIL_TOKEN=your_zeptomail_send_mail_token_here
SENDER_EMAIL=noreply@yourdomain.com
SENDER_NAME=Certificate Service
ADMIN_EMAIL=admin@yourdomain.com

# Performance Settings (Optimized for speed)
# BATCH_SIZE: Recipients per batch (higher = faster, uses more memory)
# Default: 100 (optimized for balance)
# Increase to 150-200 for maximum speed
# Decrease to 50 for conservative operation
BATCH_SIZE=100

# BATCH_DELAY_SECONDS: Wait between batches in seconds
# Default: 0.5 (half second - optimized for low latency)
# Increase to 1.0-2.0 if experiencing API throttling
# Decrease to 0.1-0.2 for maximum throughput
BATCH_DELAY_SECONDS=0.5

# Frontend Configuration
FRONTEND_ORIGIN=*

# Application Security
APP_PASSWORD=your_secure_password
